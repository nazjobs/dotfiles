return {
  "olimorris/codecompanion.nvim",
  dependencies = {
    "nvim-lua/plenary.nvim",
    "ravitemer/mcphub.nvim", -- This must be loaded first
  },
  opts = {
    llm = {
      provider = "ollama",
      model = "deepseek-coder:6.7b-instruct-q4_K_M",
      api_key = "ollama",
      api_host = "http://localhost:11434",
    },
    strategies = {
      chat = {
        tools = {
          ["mcp"] = {
            callback = function()
              return require("mcphub.extensions.codecompanion")
            end,
            opts = {
              requires_approval = false, -- Set to true if you want confirmations
            },
          },
        },
      },
      inline = {
        enabled = false, -- Disable inline to avoid errors
      },
    },
  },
  config = function(_, opts)
    require("codecompanion").setup(opts)

    vim.keymap.set("n", "<leader>cc", "<cmd>CodeCompanion<CR>", { desc = "CodeCompanion Toggle" })
    vim.keymap.set("n", "<leader>ca", "<cmd>CodeCompanionActions<CR>", { desc = "CodeCompanion Actions" })
  end,
}
