return {
  -- Enable the Copilot extra
  { "LazyVim/LazyVim", opts = { extras = { "ai.copilot" } } },

  -- Optional: Customize the Copilot setup
  {
    "zbirenbaum/copilot.lua",
    opts = {
      suggestion = {
        -- Enable suggestions to be used with copilot-cmp
        auto_trigger = true,
      },
      panel = { enabled = false }, -- Disable the separate panel, use cmp for inline suggestions
    },
  },

  -- Integrate Copilot with nvim-cmp
  {
    "zbirenbaum/copilot-cmp",
    dependencies = { "zbirenbaum/copilot.lua" },
    opts = {},
    config = function(_, opts)
      local copilot_cmp = require("copilot_cmp")
      copilot_cmp.setup(opts)
      -- Attach cmp source whenever copilot attaches
      vim.api.nvim_create_autocmd("LspAttach", {
        callback = function(args)
          local client = vim.lsp.get_client_by_id(args.data.client_id)
          if client and client.name == "copilot" then
            copilot_cmp._on_insert_enter({})
          end
        end,
      })
    end,
  },
}
